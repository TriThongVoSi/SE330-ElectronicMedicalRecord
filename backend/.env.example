# Copy this file to .env and replace all values before running.

# Runtime profile
SPRING_PROFILES_ACTIVE=dev

# App and mail behavior
APP_URL=http://localhost:5173
MAIL_ENABLED=true

# JWT
JWT_SIGNER_KEY=replace-with-a-random-secret-at-least-64-bytes
JWT_VALID_DURATION=3600
JWT_REFRESHABLE_DURATION=36000

# Database
DB_URL=jdbc:mysql://localhost:3306/se330db
DB_USER=springuser
DB_PASS=springpass

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=replace-with-app-password
SMTP_AUTH=true
SMTP_STARTTLS=true
SMTP_FROM=your-email@example.com

# Password reset
RESET_TOKEN_VALID_MINUTES=15
PASSWORD_RESET_RATE_LIMIT_MAX=3
PASSWORD_RESET_RATE_LIMIT_WINDOW_MINUTES=15

# OTP
OTP_HASH_SECRET=replace-with-a-random-secret-at-least-32-characters
